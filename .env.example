# MongoDB — get from MongoDB Atlas (free: cloud.mongodb.com)
#   Sign up → Create cluster → "Connect" → "Drivers" → copy connection string
#   Replace <password> with your db user password, <dbname> with your db name
MONGODB_URI=mongodb+srv://<dbuser>:<dbpassword>@cluster0.xxxxx.mongodb.net/tradefair-auth?retryWrites=true&w=majority

# NextAuth v5 — run `openssl rand -base64 32` to generate
AUTH_SECRET=your-random-secret-here
# Set this to your production URL (e.g. https://tradefair.vercel.app)
AUTH_URL=https://your-app.vercel.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP (for password reset) — optional, can use Gmail App Passwords or any provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-app-password

# URL — set to your Vercel domain after deploy (e.g. https://tradefair.vercel.app)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
CORS_ORIGIN=https://your-app.vercel.app

# Paystack — get from paystack.com dashboard (test keys are fine)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
